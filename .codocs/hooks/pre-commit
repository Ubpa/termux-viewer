#!/usr/bin/env bash
# codocs pre-commit hook (auto-installed by codocs init)
# 检测受管控的代码文件改动时，若无对应 .codocs/docs/ 文档改动，
# 提示用户并设置标记供 commit-msg hook 做最终判断。

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
CODOCS_CONFIG="$ROOT/.codocs/config.json"

# 没有 .codocs/config.json 则跳过
if [ ! -f "$CODOCS_CONFIG" ]; then
  exit 0
fi

PYTHON=$(command -v python 2>/dev/null || command -v python3 2>/dev/null)
if [ -z "$PYTHON" ]; then
  echo "[codocs] ERROR: python not found, cannot check doc coverage" >&2
  echo "         Install Python or run with --no-verify to bypass." >&2
  exit 1
fi
# Verify the python binary actually works (Windows Store stub may be a no-op)
if ! "$PYTHON" -c "import sys" 2>/dev/null; then
  echo "[codocs] ERROR: python found at $PYTHON but cannot execute" >&2
  exit 1
fi

# 从 .codocs/config.json 读取 roots（tr -d '\r' 处理 Windows CRLF）
mapfile -t roots < <("$PYTHON" -c "
import json
d = json.load(open('$CODOCS_CONFIG'))
for r in d.get('roots', []):
    print(r)
" 2>/dev/null | tr -d '\r')

if [ ${#roots[@]} -eq 0 ]; then
  exit 0
fi

# 获取暂存文件列表
staged_files=$(git diff --cached --name-only --diff-filter=ACMRT)

if [ -z "$staged_files" ]; then
  exit 0
fi

# 找出受管控的代码文件（在任意 root 下，排除 .css）
managed_code_files=()
while IFS= read -r f; do
  for root in "${roots[@]}"; do
    if [[ "$f" == ${root}/* ]] && [[ "$f" != *.css ]]; then
      managed_code_files+=("$f")
      break
    fi
  done
done <<< "$staged_files"

if [ ${#managed_code_files[@]} -eq 0 ]; then
  exit 0
fi

# 检查是否有 .codocs/docs/ 改动
has_doc_change=false
while IFS= read -r f; do
  if [[ "$f" == .codocs/docs/* ]]; then
    has_doc_change=true
    break
  fi
done <<< "$staged_files"

if [ "$has_doc_change" = false ]; then
  # 写入受管控文件列表，供 commit-msg hook 读取
  printf "%s\n" "${managed_code_files[@]}" > "${TMPDIR:-/tmp}/codocs_pending_files"
  touch "${TMPDIR:-/tmp}/codocs_needs_doc_check"

  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  codocs: 检测到受管控文件改动，但未找到文档更新              ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  echo "以下文件在 codocs 管控范围内："
  for f in "${managed_code_files[@]}"; do
    echo "  • $f"
  done
  echo ""
  echo "选项 A（推荐）：同时 git add 对应的 .codocs/docs/ 文档改动"
  echo "选项 B：在 commit message body 加标记跳过："
  echo "         doc: skip(<理由>)"
  echo "         例如：doc: skip(仅内部实现，接口无变化)"
  echo "选项 C：git commit --no-verify（不推荐）"
  echo ""
  exit 0
fi

# 有文档改动，清除标记
rm -f "${TMPDIR:-/tmp}/codocs_pending_files" "${TMPDIR:-/tmp}/codocs_needs_doc_check"
exit 0
